    },

    {
      "@id": "arch:datastore/session-state",
      "@type": "arch:DataStore",
      "name": "Streamlit Session State",
      "description": "In-memory session state storing: model instance, processor instance, audio_data (numpy array), last_transcript_text, gpt responses, selected_model_key, and language_token. Ephemeral — lost on page refresh.",
      "arch:techStack": ["Streamlit"],
      "arch:exposesPort": null,
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:datastore/model-cache",
      "@type": "arch:DataStore",
      "name": "HuggingFace Model Cache",
      "description": "Local filesystem cache for downloaded Whisper model weights. Managed by HuggingFace hub. Default location: ~/.cache/huggingface/. Approximately 4GB per model.",
      "arch:techStack": ["HuggingFace Hub"],
      "arch:exposesPort": null,
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:datastore/temp-files",
      "@type": "arch:DataStore",
      "name": "Temporary Audio Files",
      "description": "System temp directory used for uploaded file processing and recording playback. Files created via tempfile.NamedTemporaryFile and temp_recording.wav. Cleaned up in finally blocks.",
      "arch:techStack": ["Python tempfile"],
      "arch:exposesPort": null,
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:external/portaudio",
      "@type": "arch:ExternalDependency",
      "name": "PortAudio",
      "description": "System-level audio I/O library. Required by sounddevice for microphone capture. Must be installed via package manager (brew/apt/dnf).",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:external/ffmpeg",
      "@type": "arch:ExternalDependency",
      "name": "FFmpeg",
      "description": "Audio format conversion called via subprocess. Required for M4A, MP3, OGG, WebM to WAV conversion. Must be installed as a system package.",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T06:30:00Z"
    },

    {
      "@id": "arch:external/huggingface-model-icelandic",
      "@type": "arch:ExternalDependency",
      "name": "Icelandic Whisper Model",
      "description": "Fine-tuned Whisper Large model: carlosdanielhernandezmena/whisper-large-icelandic-10k-steps-1000h. Downloaded once from HuggingFace Hub, cached locally.",
      "url": "https://huggingface.co/carlosdanielhernandezmena/whisper-large-icelandic-10k-steps-1000h",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:external/huggingface-model-english",
      "@type": "arch:ExternalDependency",
      "name": "English Whisper Model",
      "description": "OpenAI Whisper Large v3: openai/whisper-large-v3. Downloaded once from HuggingFace Hub, cached locally.",
      "url": "https://huggingface.co/openai/whisper-large-v3",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:external/pytorch",
      "@type": "arch:ExternalDependency",
      "name": "PyTorch Runtime",
      "description": "Deep learning framework for model inference. CUDA used when available, CPU fallback. Handles tensor operations and model execution.",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:external/openai-api",
      "@type": "arch:ExternalDependency",
      "name": "OpenAI API",
      "description": "Optional external API for GPT post-processing. Only sends transcribed text (not audio). Requires OPENAI_API_KEY environment variable. Default model: gpt-4o-mini.",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:flow/mic-to-transcription",
      "@type": "arch:DataFlow",
      "name": "Microphone Recording Flow",
      "description": "User clicks Record -> AudioStream captures chunks at native sample rate -> resamples to 16kHz -> concatenates -> Whisper model inference -> text displayed in UI",
      "arch:source": "arch:external/portaudio",
      "arch:target": "arch:service/transcribe-module",
      "arch:protocol": "in-process",
      "arch:dataType": "numpy.float32 audio array (16kHz mono)",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:flow/upload-to-transcription",
      "@type": "arch:DataFlow",
      "name": "File Upload Flow",
      "description": "User uploads audio file -> saved to temp file -> M4A converted via pydub/FFmpeg -> read with soundfile -> resampled to 16kHz -> chunked into 30s segments -> each chunk transcribed -> timestamped results displayed with TXT/SRT export",
      "arch:source": "arch:service/streamlit-app",
      "arch:target": "arch:service/transcribe-module",
      "arch:protocol": "in-process",
      "arch:dataType": "numpy.float32 audio array (16kHz mono)",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:flow/transcript-to-gpt",
      "@type": "arch:DataFlow",
      "name": "GPT Post-Processing Flow",
      "description": "User provides instruction + transcript text -> sent to OpenAI API via gpt.run_on_transcript() -> response displayed in expandable panel. Only text is sent, never audio.",
      "arch:source": "arch:service/streamlit-app",
      "arch:target": "arch:external/openai-api",
      "arch:protocol": "HTTPS REST",
      "arch:dataType": "JSON (chat completions)",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:flow/model-download",
      "@type": "arch:DataFlow",
      "name": "Model Download Flow",
      "description": "First launch: HuggingFace Hub downloads model weights (~4GB) -> cached in ~/.cache/huggingface/ -> subsequent launches load from cache (no network needed)",
      "arch:source": "arch:external/huggingface-model-icelandic",
      "arch:target": "arch:datastore/model-cache",
      "arch:protocol": "HTTPS",
      "arch:dataType": "PyTorch model weights + tokenizer config",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:infra/streamlit-config",
      "@type": "arch:Infrastructure",
      "name": "Streamlit Configuration",
      "description": "Server config: max upload 1000MB, error-only logging. Located at .streamlit/config.toml.",
      "arch:exposesPort": 8501,
      "arch:configuredIn": ".streamlit/config.toml",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:infra/github-actions-ci",
      "@type": "arch:Infrastructure",
      "name": "GitHub Actions CI",
      "description": "Automated CI pipeline running pytest across Python 3.10-3.12, with pip-audit vulnerability scanning. Triggers on push to main and PRs.",
      "arch:exposesPort": null,
