      "name": "Legacy Monolithic App",
      "description": "DEPRECATED AND REMOVED: Original single-file application (sst_is_test.py). Deleted in modernize/2026-03-14 branch. All functionality lives in whisperSSTis/ package.",
      "arch:deprecated": true,
      "arch:exposesPort": null,
