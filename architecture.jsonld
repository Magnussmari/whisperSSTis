  "@graph": [
    {
      "@id": "arch:system/whispersstis",
      "@type": "arch:System",
      "name": "WhisperSST.is",
      "description": "Local-first Icelandic and English speech recognition application using fine-tuned Whisper models. Streamlit web UI with optional GPT post-processing. 100% local audio processing.",
      "arch:lastAuditedBy": "claude-code/self-optimize",
      "arch:lastAuditedAt": "2026-03-14T06:15:00Z",
      "arch:techStack": ["Python 3.10+", "Streamlit", "PyTorch", "HuggingFace Transformers", "sounddevice", "soundfile", "scipy", "pydub", "OpenAI SDK (optional)"],
      "url": "https://github.com/Magnussmari/whisperSSTis",
      "license": "https://spdx.org/licenses/MIT"
    },

    {
      "@id": "arch:service/streamlit-app",
      "@type": "arch:Service",
      "name": "Streamlit Web Application",
      "description": "Main user-facing web interface (app.py). Provides audio recording, file upload, model selection, transcription display, and export to TXT/SRT. Manages session state for model and audio data.",
      "arch:dependsOn": [
        "arch:service/audio-module",
        "arch:service/transcribe-module",
        "arch:service/gpt-module"
      ],
      "arch:exposesPort": 8501,
      "arch:techStack": ["Streamlit", "Python"],
      "arch:healthEndpoint": null,
      "arch:configuredIn": "app.py",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:service/audio-module",
      "@type": "arch:Service",
      "name": "Audio Module",
      "description": "Core audio capture and file processing (whisperSSTis/audio.py). Handles device enumeration, real-time recording via AudioStream class, file loading with format conversion, resampling to 16kHz, and mono conversion.",
      "arch:dependsOn": [
        "arch:external/portaudio",
        "arch:external/ffmpeg"
      ],
      "arch:exposesPort": null,
      "arch:techStack": ["sounddevice", "soundfile", "scipy", "numpy", "subprocess/ffmpeg"],
      "arch:configuredIn": "whisperSSTis/audio.py",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:service/transcribe-module",
      "@type": "arch:Service",
      "name": "Transcription Module",
      "description": "Whisper model loading and inference (whisperSSTis/transcribe.py). Supports multiple model configs (Icelandic, English), chunk-based long audio transcription with timestamps, and SRT subtitle generation.",
      "arch:dependsOn": [
        "arch:external/huggingface-model-icelandic",
        "arch:external/huggingface-model-english",
        "arch:external/pytorch"
      ],
      "arch:exposesPort": null,
      "arch:techStack": ["PyTorch", "HuggingFace Transformers", "numpy"],
      "arch:configuredIn": "whisperSSTis/transcribe.py",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:service/gpt-module",
      "@type": "arch:Service",
      "name": "GPT Post-Processing Module",
      "description": "Optional OpenAI GPT integration (whisperSSTis/gpt.py). Sends transcribed text (not audio) to GPT for summarization, translation, or cleanup. Gracefully handles missing openai package.",
      "arch:dependsOn": [
        "arch:external/openai-api"
      ],
      "arch:exposesPort": null,
      "arch:techStack": ["OpenAI Python SDK"],
      "arch:configuredIn": "whisperSSTis/gpt.py",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:service/launcher",
      "@type": "arch:Service",
      "name": "Desktop Launcher",
      "description": "Tkinter GUI launcher (launcher.py). Manages Streamlit process lifecycle, port allocation (8501), browser auto-open, and graceful shutdown. Uses psutil for process management.",
      "arch:dependsOn": [
        "arch:service/streamlit-app"
      ],
      "arch:exposesPort": null,
      "arch:techStack": ["Tkinter", "psutil", "subprocess"],
      "arch:configuredIn": "launcher.py",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:service/build-system",
      "@type": "arch:Service",
      "name": "PyInstaller Build",
      "description": "Executable packaging via PyInstaller (build.py). Creates single-file executables bundling model cache and whisperSSTis module. Produces dist/WhisperSST_package/ with platform scripts.",
      "arch:dependsOn": [
        "arch:service/launcher"
      ],
      "arch:exposesPort": null,
      "arch:techStack": ["PyInstaller"],
      "arch:configuredIn": "build.py",
      "arch:confidence": "verified",
      "arch:lastAuditedAt": "2026-03-14T05:51:00Z"
    },

    {
      "@id": "arch:service/legacy-monolith",
